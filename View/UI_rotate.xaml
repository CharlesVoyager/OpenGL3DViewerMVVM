<UserControl x:Class="View3D.view.UI_rotate"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:DesignInControl="clr-namespace:View3D.view"
             mc:Ignorable="d">
    
    <Grid Height="264" Width="280">
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="Common">
                <VisualState x:Name="StateVisible">
                    <Storyboard>
                        <ObjectAnimationUsingKeyFrames BeginTime="0:0:0" Storyboard.TargetProperty="Visibility">
                            <DiscreteObjectKeyFrame KeyTime="0">
                                <DiscreteObjectKeyFrame.Value>
                                    <Visibility>Visible</Visibility>
                                </DiscreteObjectKeyFrame.Value>
                            </DiscreteObjectKeyFrame>
                        </ObjectAnimationUsingKeyFrames>
                        <DoubleAnimation To="1" Duration="0:00:00.7" Storyboard.TargetName="State1Panel" Storyboard.TargetProperty="(UIElement.Opacity)" />
                    </Storyboard>
                </VisualState>
                <VisualState x:Name="StateHidden">
                    <Storyboard>
                        <ObjectAnimationUsingKeyFrames BeginTime="0:0:0" Storyboard.TargetProperty="Visibility">
                            <DiscreteObjectKeyFrame KeyTime="0">
                                <DiscreteObjectKeyFrame.Value>
                                    <Visibility>Hidden</Visibility>
                                </DiscreteObjectKeyFrame.Value>
                            </DiscreteObjectKeyFrame>
                        </ObjectAnimationUsingKeyFrames>
                        <DoubleAnimation To="0" Duration="0:00:00.4" Storyboard.TargetName="State1Panel" Storyboard.TargetProperty="(UIElement.Opacity)" />
                    </Storyboard>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <Border Name="State1Panel" Opacity="1" Width="280">
            <Grid x:Name="LayoutRoot" VerticalAlignment="Center" Margin="-14,0,0,0" HorizontalAlignment="Left">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Rectangle Height="80" HorizontalAlignment="Left" Margin="16,90,0,0" Name="rectangle1" Stroke="{x:Null}" VerticalAlignment="Top" Width="225 " Fill="#64FFFFFF" RadiusX="5" RadiusY="10" />
                <StackPanel Margin="14,164,0,15" Orientation="Horizontal" Width="110" Height="83" HorizontalAlignment="Left">

                    <ToggleButton Click="button_rotate_reset_Click"  Content="Reset" Height="70" Margin="2.5" Name="button_rotate_reset" Padding="3" Width="50" FontFamily="Arial">
                        <ToggleButton.Background>
                            <ImageBrush ImageSource="/OpenGL3DViewerMVVM;component/Resources/submenu_reset1.png" />
                        </ToggleButton.Background>
                    </ToggleButton>
                </StackPanel>

                <StackPanel Width="110" Height="115" Name="stackpanelX" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" MouseMove="StackPanelX_MouseMove" MouseDown="StackPanelX_MouseLeftButtonDown" Margin="-150,0,0,0" MouseLeave="stackpanelX_MouseLeave" PreviewMouseWheel="orangeX_PreviewMouseWheel">
                    <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                        <DesignInControl:CircularProgressBar HorizontalAlignment="Center" VerticalAlignment="Center" SegmentColor="White" StrokeThickness="55" Angle="360" Radius="1" />
                        <DesignInControl:CircularProgressBar HorizontalAlignment="Center" VerticalAlignment="Center" SegmentColor="#FF878889" StrokeThickness="10" Angle="360" Radius="30" />
                        <DesignInControl:CircularProgressBar HorizontalAlignment="Center" VerticalAlignment="Center" SegmentColor="Orange" StrokeThickness="10" Radius="30" x:Name="orangeX" Angle="{Binding SelectedModel.RotationX}"/>
                        <TextBox Name="textRotX" Height="auto" Background="Transparent" Foreground="Black" FontSize="20" VerticalAlignment="Center" HorizontalAlignment="Center" TextAlignment="Center" BorderBrush="Transparent" BorderThickness="0" Visibility="Hidden" FontFamily="Arial" LostFocus="textboxX_LostFocus" PreviewKeyDown="textboxX_PreviewKeyDown" Text="{Binding SelectedModel.RotationX, StringFormat={}{0:G3}, UpdateSourceTrigger=PropertyChanged}"/>
                        <Label Content="°" FontSize="20" Height="28" HorizontalAlignment="Right" Margin="0,34,28,0" VerticalAlignment="Top" Visibility="{Binding Visibility, ElementName=textRotX}" FontFamily="Arial" />
                        <Label Content="X" Name="labelX" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="30" FontFamily="Arial" />
                    </Grid>
                </StackPanel>

                <StackPanel Width="110" Height="115" Name="stackpanelY" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" MouseMove="StackPanelY_MouseMove" MouseDown="StackPanelY_MouseLeftButtonDown" Margin="-2,0,0,0" MouseLeave="stackpanelY_MouseLeave" PreviewMouseWheel="orangeY_PreviewMouseWheel">
                    <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                        <DesignInControl:CircularProgressBar HorizontalAlignment="Center" VerticalAlignment="Center" SegmentColor="White" StrokeThickness="55" Angle="360" Radius="1" />
                        <DesignInControl:CircularProgressBar HorizontalAlignment="Center" VerticalAlignment="Center" SegmentColor="#FF878889" StrokeThickness="10" Angle="360" Radius="30" />
                        <DesignInControl:CircularProgressBar HorizontalAlignment="Center" VerticalAlignment="Center" SegmentColor="Orange" StrokeThickness="10" Radius="30" x:Name="orangeY" Angle="{Binding SelectedModel.RotationY}"/>
                        <TextBox Name="textRotY" Height="auto" Background="Transparent" Foreground="Black" FontSize="20" VerticalAlignment="Center" HorizontalAlignment="Center" TextAlignment="Center" BorderBrush="Transparent" BorderThickness="0" Visibility="Hidden" FontFamily="Arial" LostFocus="textboxY_LostFocus" PreviewKeyDown="textboxY_PreviewKeyDown" Text="{Binding SelectedModel.RotationY, StringFormat={}{0:G3}, UpdateSourceTrigger=PropertyChanged}"/>
                        <Label Content="°" FontSize="20" Height="28" HorizontalAlignment="Right" Margin="0,33,29,0" VerticalAlignment="Top" Visibility="{Binding Visibility, ElementName=textRotY}" FontFamily="Arial" />
                        <Label Content="Y" Name="labelY" FontSize="30" HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Arial" />
                    </Grid>
                </StackPanel>

                <StackPanel Width="110" Height="115" Name="stackpanelZ" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" MouseMove="StackPanelZ_MouseMove" MouseDown="StackPanelZ_MouseLeftButtonDown" Margin="146,0,0,0" MouseLeave="stackpanelZ_MouseLeave" PreviewMouseWheel="orangeZ_PreviewMouseWheel">
                    <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                        <DesignInControl:CircularProgressBar HorizontalAlignment="Center" VerticalAlignment="Center" SegmentColor="White" StrokeThickness="55" Angle="360" Radius="1" />
                        <DesignInControl:CircularProgressBar HorizontalAlignment="Center" VerticalAlignment="Center" SegmentColor="#FF878889" StrokeThickness="10" Angle="360" Radius="30" />
                        <DesignInControl:CircularProgressBar HorizontalAlignment="Center" VerticalAlignment="Center" SegmentColor="Orange" StrokeThickness="10" Radius="30" x:Name="orangeZ" Angle="{Binding SelectedModel.RotationZ}"/>
                        <TextBox Name="textRotZ" Height="auto" Background="Transparent" Foreground="Black" FontSize="20" VerticalAlignment="Center" HorizontalAlignment="Center" TextAlignment="Center" BorderBrush="Transparent" BorderThickness="0" Visibility="Hidden" FontFamily="Arial" LostFocus="textboxZ_LostFocus" PreviewKeyDown="textboxZ_PreviewKeyDown" Text="{Binding SelectedModel.RotationZ, StringFormat={}{0:G3}, UpdateSourceTrigger=PropertyChanged}"/>
                        <Label Content="°" Height="28" HorizontalAlignment="Right" Margin="0,35,28,0" VerticalAlignment="Top" FontSize="20" Visibility="{Binding Visibility, ElementName=textRotZ}" FontFamily="Arial" />
                        <Label Content="Z" Name="labelZ" FontSize="30" HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Arial" />
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>

</UserControl>
