<Window x:Class="OpenGL3DViewerMVVM.View.STLComposer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             Height="540" 
             Width="400"
             Title="STLComposer"
             ResizeMode="NoResize" Closing="Window_Closing">

    <Window.Resources>
        <!-- Validation error style for TextBox -->
        <Style x:Key="ValidatedTextBox" TargetType="TextBox">
            <Setter Property="IsEnabled" Value="True"/>
            <Style.Triggers>
                <Trigger Property="Validation.HasError" Value="True">
                    <Setter Property="ToolTip"
                            Value="{Binding RelativeSource={RelativeSource Self}, Path=(Validation.Errors)[0].ErrorContent}"/>
                    <Setter Property="BorderBrush" Value="Red"/>
                </Trigger>
                <DataTrigger Binding="{Binding SelectedModel}" Value="{x:Null}">
                    <Setter Property="IsEnabled" Value="False"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="panelAnalysisBorderStyle" TargetType="Border">
            <Setter Property="Visibility" Value="Visible"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding SelectedModel}" Value="{x:Null}">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
       
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="180"/> <!-- List -->
            <RowDefinition Height="30"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DataGrid
            ItemsSource="{Binding Models}"
            SelectedItem="{Binding SelectedModel}"
            CanUserAddRows="False" CanUserDeleteRows="False" CanUserResizeRows="False"
            AutoGenerateColumns="False"
            IsReadOnly="True"
            Margin="4,2">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="200"/>
                <DataGridTextColumn Header="Trangles" Binding="{Binding Triangles}" Width="80"/>
                <DataGridTextColumn Header="Outside" Binding="{Binding Outside}" Width="60"/>
            </DataGrid.Columns>
        </DataGrid>
        
        <StackPanel Grid.Row="1" Orientation="Horizontal">
            <Button Content="Add" Margin="4,2" Padding="6,2" Command="{Binding AddCommand}"/>
            <Button Content="Delete" Margin="4,2" Padding="6,2" Command="{Binding DeleteCommand}"/>
            <Button Content="Clone" Margin="4,2" Padding="6,2" Command="{Binding CloneCommand}"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Vertical">
            <!-- ═══════════════════════════════════════════
                 panel1  –  Trans / Scale / Rotate controls
                 ═══════════════════════════════════════════ -->
            <Border Height="107" BorderBrush="Gray" BorderThickness="0.5" CornerRadius="3" Padding="10" Margin="4,2">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>   <!-- row labels -->
                        <ColumnDefinition Width="Auto"/> <!-- X label -->
                        <ColumnDefinition Width="68"/>   <!-- X value -->
                        <ColumnDefinition Width="Auto"/> <!-- Y label -->
                        <ColumnDefinition Width="68"/>   <!-- Y value -->
                        <ColumnDefinition Width="Auto"/> <!-- Z label -->
                        <ColumnDefinition Width="68"/>   <!-- Z value -->
                        <ColumnDefinition Width="*"/>    <!-- LockAspect -->
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="28"/>
                        <RowDefinition Height="28"/>
                        <RowDefinition Height="28"/>
                    </Grid.RowDefinitions>

                    <!-- Row labels -->
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Trans" VerticalAlignment="Center" Margin="4,0"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Rotate" VerticalAlignment="Center" Margin="4,0"/>
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Scale" VerticalAlignment="Center" Margin="4,0"/>

                    <!-- Trans -->
                    <TextBox x:Name="textTransX" Grid.Row="0" Grid.Column="2"
                             Margin="4,4" VerticalAlignment="Center"
                             Style="{StaticResource ValidatedTextBox}"
                             Text="{Binding SelectedModel.PositionX, StringFormat={}{0:G3}, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBox x:Name="textTransY" Grid.Row="0" Grid.Column="4"
                             Margin="4,4" VerticalAlignment="Center"
                             Style="{StaticResource ValidatedTextBox}"
                             Text="{Binding SelectedModel.PositionY, StringFormat={}{0:G3}, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBox x:Name="textTransZ" Grid.Row="0" Grid.Column="6"
                             Margin="4,4" VerticalAlignment="Center"
                             Style="{StaticResource ValidatedTextBox}"
                             Text="{Binding SelectedModel.PositionZ, StringFormat={}{0:G3}, UpdateSourceTrigger=PropertyChanged}"/>

                    <!-- Rotate -->
                    <TextBox x:Name="textRotX" Grid.Row="1" Grid.Column="2"
                            Margin="4,4" VerticalAlignment="Center"
                            Style="{StaticResource ValidatedTextBox}"
                            Text="{Binding SelectedModel.RotationX, StringFormat={}{0:G3}, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBox x:Name="textRotY" Grid.Row="1" Grid.Column="4"
                            Margin="4,4" VerticalAlignment="Center"
                            Style="{StaticResource ValidatedTextBox}"
                            Text="{Binding SelectedModel.RotationY, StringFormat={}{0:G3}, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBox x:Name="textRotZ" Grid.Row="1" Grid.Column="6"
                            Margin="4,4" VerticalAlignment="Center"
                            Style="{StaticResource ValidatedTextBox}"
                            Text="{Binding SelectedModel.RotationZ, StringFormat={}{0:G3}, UpdateSourceTrigger=PropertyChanged}"/>

                    <!-- Scale -->
                    <TextBox x:Name="textScaleX" Grid.Row="2" Grid.Column="2" Margin="4,4" VerticalAlignment="Center"
                             Style="{StaticResource ValidatedTextBox}"
                             Text="{Binding SelectedModel.ScaleX, StringFormat={}{0:G3}, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBox x:Name="textScaleY" Grid.Row="2" Grid.Column="4" Margin="4,4" VerticalAlignment="Center"
                             Style="{StaticResource ValidatedTextBox}"
                             Text="{Binding SelectedModel.ScaleY, StringFormat={}{0:G3}, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBox x:Name="textScaleZ" Grid.Row="2" Grid.Column="6" Margin="4,4" VerticalAlignment="Center"
                             Style="{StaticResource ValidatedTextBox}"
                             Text="{Binding SelectedModel.ScaleZ, StringFormat={}{0:G3}, UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>
            </Border>

            <!-- ═══════════════════════════════════════════
                 panelAnalysis  –  Object Analysis GroupBox
                 ═══════════════════════════════════════════ -->
            <Border Height="150" Style="{StaticResource panelAnalysisBorderStyle}">
                <GroupBox Header="Object Analysis" Margin="4,2" Background="White" x:Name="groupBoxObjectAnalysis">
                    <Grid Margin="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="45*"/>
                            <ColumnDefinition Width="35*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="24"/>
                            <RowDefinition Height="24"/>
                            <RowDefinition Height="24"/>
                            <RowDefinition Height="24"/>
                            <RowDefinition Height="24"/>
                            <RowDefinition Height="24"/>
                        </Grid.RowDefinitions>

                        <!-- Row 0 – Original Model Size -->
                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Text="Original Model Size (X, Y, Z):"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="0" Grid.Column="1"
                                   Text="{Binding SelectedModel.OriginalModelSize, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center"/>

                        <!-- Row 1 – Triangles -->
                        <TextBlock Grid.Row="1" Grid.Column="0"
                                   Text="Triangles:" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="1" Grid.Column="1"
                                   Text="{Binding SelectedModel.Triangles, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center"/>

                        <!-- Row 2 – Debug Info -->
                        <TextBlock Grid.Row="2" Grid.Column="0"
                                   Text="Debug Info:" VerticalAlignment="Center"/>
                        <TextBlock x:Name="txtDebugInfo"
                                   Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Text="" VerticalAlignment="Center"/>
                    </Grid>
                </GroupBox>
            </Border>
        </StackPanel>
    </Grid>
</Window>
