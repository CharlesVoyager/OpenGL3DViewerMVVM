<UserControl x:Class="OpenGL3DViewerMVVM.View.UI_resize_advance"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="300" >

    <Grid>
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="Common">
                <VisualState x:Name="StateVisible">
                    <Storyboard>
                        <ObjectAnimationUsingKeyFrames BeginTime="0:0:0" Storyboard.TargetProperty="Visibility">
                            <DiscreteObjectKeyFrame KeyTime="0">
                                <DiscreteObjectKeyFrame.Value>
                                    <Visibility>Visible</Visibility>
                                </DiscreteObjectKeyFrame.Value>
                            </DiscreteObjectKeyFrame>
                        </ObjectAnimationUsingKeyFrames>
                        <DoubleAnimation To="1" Duration="0:00:00.7" Storyboard.TargetName="State1Panel" Storyboard.TargetProperty="(UIElement.Opacity)" />
                    </Storyboard>
                </VisualState>
                <VisualState x:Name="StateHidden">
                    <Storyboard>
                        <ObjectAnimationUsingKeyFrames BeginTime="0:0:0" Storyboard.TargetProperty="Visibility">
                            <DiscreteObjectKeyFrame KeyTime="0">
                                <DiscreteObjectKeyFrame.Value>
                                    <Visibility>Hidden</Visibility>
                                </DiscreteObjectKeyFrame.Value>
                            </DiscreteObjectKeyFrame>
                        </ObjectAnimationUsingKeyFrames>
                        <DoubleAnimation To="0" Duration="0:00:00.4" Storyboard.TargetName="State1Panel" Storyboard.TargetProperty="(UIElement.Opacity)" />
                    </Storyboard>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <!-- DataGrid is used for receiving SelectedModel changed. -->
        <DataGrid
            ItemsSource="{Binding Models}"
            SelectedItem="{Binding SelectedModel}"
            SelectionChanged="OnSelectionChange"
            CanUserAddRows="False" CanUserDeleteRows="False" CanUserResizeRows="False"
            AutoGenerateColumns="False"
            IsReadOnly="True"
            Visibility="Hidden">
        </DataGrid>
        
        <Border Name="State1Panel" Opacity="1" Height="300" Margin="0">

            <Border.Background>
                <SolidColorBrush />
            </Border.Background>
            <Grid HorizontalAlignment="Center" VerticalAlignment="Center" >
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                </Grid.RowDefinitions>
                <Grid x:Name="Main_resize" Width="220" Height="180" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" >
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60*" />
                        <ColumnDefinition Width="91*" />
                        <ColumnDefinition Width="67*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition Height="30"/>
                    </Grid.RowDefinitions>
                    <Border  Opacity="1" Grid.ColumnSpan="3" Grid.RowSpan="7">
                        <Border.Background>
                            <SolidColorBrush />
                        </Border.Background>
                        <Rectangle Name="rectangle1" Fill="#C8F7931E" Margin="0,0,0,0" />
                    </Border>
                    <Label x:Name="lbl_X" Content="Size X" Height="28" HorizontalAlignment="Center" VerticalAlignment="Bottom" Foreground="White" FontFamily="Arial" Grid.Column="0" Grid.Row="0" />
                    <TextBox x:Name="txtX" Height="20" Background="White" TextAlignment="Right" Margin="5,0,5,0"  Grid.Column="1" Grid.Row="0" TextChanged="txtX_TextChanged" LostFocus="scaleLostFocus" />
                    <Label x:Name="lbl_XUnits" Content="mm" Height="28" HorizontalAlignment="Left" VerticalAlignment="Bottom" Foreground="White" FontFamily="Arial" Grid.Column="2" Grid.Row="0" />
                    <Label x:Name="lbl_Y" Content="Size Y" Height="28" HorizontalAlignment="Center" VerticalAlignment="Bottom" Foreground="White" FontFamily="Arial" Grid.Column="0" Grid.Row="1" />
                    <TextBox x:Name="txtY" Height="20"  Background="White" TextAlignment="Right" Margin="5,0,5,0"  Grid.Column="1" Grid.Row="1" TextChanged="txtY_TextChanged" LostFocus="scaleLostFocus"/>
                    <Label x:Name="lbl_YUnits" Content="mm" Height="28" HorizontalAlignment="Left" VerticalAlignment="Bottom" Foreground="White" FontFamily="Arial" Grid.Column="2" Grid.Row="1" />
                    <Label x:Name="lbl_Z" Content="Size Z" Height="28" HorizontalAlignment="Center" VerticalAlignment="Bottom" Foreground="White" FontFamily="Arial" Grid.Column="0" Grid.Row="2" />
                    <TextBox x:Name="txtZ" Height="20"  Background="White" TextAlignment="Right" Margin="5,0,5,0"  Grid.Column="1" Grid.Row="2" TextChanged="txtZ_TextChanged" LostFocus="scaleLostFocus"/>
                    <Label x:Name="lbl_ZUnits" Content="mm" Height="28" HorizontalAlignment="Left" VerticalAlignment="Bottom" Foreground="White" FontFamily="Arial" Grid.Column="2" Grid.Row="2" />
                    <CheckBox x:Name="chk_Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"  Grid.Column="0" Grid.Row="3" IsChecked="True" Checked="chk_Uniform_Checked" Unchecked="chk_Uniform_UnChecked" >
                        <CheckBox.LayoutTransform>
                            <ScaleTransform ScaleX="1.5" ScaleY="1.5" />
                        </CheckBox.LayoutTransform>
                    </CheckBox>
                    <Label x:Name="lbl_Uniform" Content="Uniform" Height="28" HorizontalAlignment="Left" VerticalAlignment="Center" Foreground="White" FontFamily="Arial" Grid.Column="1" Grid.Row="3" Width="120" Margin="0,4,0,0" />
                    <Label x:Name="lbl_Size" Content="Size" Height="28" HorizontalAlignment="Center" Foreground="White" FontFamily="Arial" Grid.Column="0" Grid.Row="4" Margin="10,3.6,91.385,28.8" Grid.RowSpan="2" Width="51" Grid.ColumnSpan="2" />
                    <Slider x:Name="slider_resize" Height="12" HorizontalAlignment="Left" VerticalAlignment="Top" Width="140" Opacity="1" Foreground="{x:Null}" Maximum="200" Value="100" Minimum="0" TickFrequency="0.01" LargeChange="0.01" SmallChange="0.01" Margin="75,7,0,0" Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="4" ValueChanged="slider_resize_ValueChanged"  PreviewMouseWheel="slider_resize_PreviewMouseWheel">
                        <Slider.Resources>
                            <Style TargetType="{x:Type Slider}">
                                <Setter Property="Background" Value="white"/>
                                <Setter Property="Height" Value="20"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="{x:Type Slider}">
                                            <ControlTemplate.Resources>
                                                <Style TargetType="{x:Type RepeatButton}">
                                                    <Setter Property="OverridesDefaultStyle" Value="true"/>
                                                    <Setter Property="IsTabStop" Value="false"/>
                                                    <Setter Property="Focusable" Value="false"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="{x:Type RepeatButton}">
                                                                <Border Background="{TemplateBinding Background}"/>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                                <PathGeometry x:Key="Triangle" >
                                                    <PathFigure StartPoint="1,1">
                                                        <LineSegment Point="1,1"/>
                                                        <LineSegment Point="1,0"/>
                                                        <LineSegment Point="0,1"/>
                                                    </PathFigure>
                                                </PathGeometry>
                                            </ControlTemplate.Resources>
                                            <Grid>
                                                <Grid>
                                                    <Grid.OpacityMask>
                                                        <DrawingBrush>
                                                            <DrawingBrush.Drawing>
                                                                <GeometryDrawing Brush="White" Geometry="{StaticResource Triangle}"/>
                                                            </DrawingBrush.Drawing>
                                                        </DrawingBrush>
                                                    </Grid.OpacityMask>
                                                    <Track Name="PART_Track" Value="{TemplateBinding Value}" >
                                                        <Track.Thumb>
                                                            <Thumb Width="10" Background="White" Cursor="Hand">
                                                                <Thumb.Template>
                                                                    <ControlTemplate TargetType="{x:Type Thumb}">
                                                                        <Border Background="{TemplateBinding Background}"/>
                                                                    </ControlTemplate>
                                                                </Thumb.Template>
                                                            </Thumb>

                                                        </Track.Thumb>
                                                        <Track.DecreaseRepeatButton>
                                                            <RepeatButton Background="{TemplateBinding Background}" Command="Slider.DecreaseLarge"/>
                                                        </Track.DecreaseRepeatButton>
                                                        <Track.IncreaseRepeatButton>
                                                            <RepeatButton Background="Transparent" Command="Slider.IncreaseLarge"/>
                                                        </Track.IncreaseRepeatButton>
                                                    </Track>
                                                </Grid>
                                                <Path Data="{StaticResource Triangle}" Stretch="Fill" Stroke="White" StrokeThickness="3"/>               
                                            </Grid>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Slider.Resources>
                    </Slider>
                    <!--
                    'slider_resize and slider_resizeTemp is binding together. 
                    slider_resizeTemp is normal silder with default style.
                    slider_resize is custom style with triangle background.
                    -->
                    <Slider Height="23" HorizontalAlignment="Left" VerticalAlignment="Bottom" Width="150" Maximum="{Binding ElementName=slider_resize, Path=Maximum}" Minimum="{Binding ElementName=slider_resize, Path=Minimum}" TickFrequency="0.01" LargeChange="0.01" SmallChange="0.01" Margin="70,0,0,0" Grid.ColumnSpan="3" Grid.Row="4" Value="{Binding ElementName=slider_resize, Path=Value}" TickPlacement="None" FontStretch="Normal" Foreground="White" IsEnabled="{Binding ElementName=slider_resize, Path=IsEnabled}"/>
                    <Label x:Name="lbl_Scale" Content="100%" Height="28" HorizontalAlignment="Left" Foreground="White" Margin="10,2.4,0,0" FontFamily="Arial" Grid.Column="0" Grid.Row="5" Width="41"/>
                    <TextBox Height="20" Background="White" Margin="15,0,15,0" Grid.Column="1" Grid.Row="5" TextAlignment="Right" Text="{Binding ElementName=slider_resize, Path=Value, StringFormat={}{0:0}}" IsEnabled="{Binding ElementName=slider_resize, Path=IsEnabled}"/>
                    <Label Content="%" Height="28" HorizontalAlignment="Left" Foreground="White" Margin="75,2.4,0,0" FontFamily="Arial" Grid.Column="1" Grid.ColumnSpan="2" Grid.Row="5"/>
                    <Button x:Name="btn_Scale" Content="Apply" Height="25" Margin="4,0,5,0" Grid.Column="2" Grid.Row="5" Click="btn_Scale_Click" IsEnabled="{Binding ElementName=slider_resize, Path=IsEnabled}"/>
                </Grid>
                <StackPanel Orientation="Vertical" Width="160" Height="75" Background="#C8F7931E" Grid.Row="1" Grid.Column="0" Margin="0,5,2.4,0">
                    <Button Height="28" Margin="0,5" x:Name="button_mmtoinch" Padding="3" Width="155" Content="Scale Up (mm→inch)" FontFamily="Arial" Click="button_mmtoinch_Click" FontSize="11"/>
                    <Button Height="28" Margin="1" x:Name="button_inchtomm" Padding="3" Width="155" Content="Scale Down (inch→mm)" FontFamily="Arial" Click="button_inchtomm_Click" FontSize="11"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Grid.Row="1" Grid.Column="1" Margin="0,5,0,0" >
                    <ToggleButton Height="70" Margin="2.5,3,2.5,2.2" x:Name="button_Reset" Padding="3" Width="50" Content="Reset" FontFamily="Arial" Click="button_Reset_Click" >
                        <ToggleButton.Background>
                            <ImageBrush ImageSource="/OpenGL3DViewerMVVM;component/Resources/submenu_reset1.png" />
                        </ToggleButton.Background>
                    </ToggleButton>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
