<Window x:Class="OpenGL3DViewerMVVM.View.ThreeDSettings"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="3D Visualization Settings"
        xmlns:local="clr-namespace:OpenGL3DViewerMVVM.View"        
        Width="660" Height="500"
        ResizeMode="NoResize"
        Topmost="True"
        Closing="ThreeDSettings_Closing"
        Closed="ThreeDSettings_Closed">

    <Window.Resources>
        <Style x:Key="SwatchStyle" TargetType="Border">
            <Setter Property="BorderBrush" Value="#888"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,3"/>
        </Style>

        <local:BrushToFloatConverter x:Key="BrushToFloatConverter"/>
        <local:UIntToBrushConverter x:Key="UIntToBrushConverter"/>
        
    </Window.Resources>

    <Grid Margin="10">
        <TabControl>

            <!-- ═══════════════════════════════════════════
                 TAB 1 — General
            ════════════════════════════════════════════ -->
            <TabItem Header="General">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <GroupBox Header="Print Area" Grid.Row="0" Margin="0,0,0,10">
                        <Grid Margin="2,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="30"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="34"/>
                                <RowDefinition Height="34"/>
                                <RowDefinition Height="34"/>
                                <RowDefinition Height="34"/>
                                <RowDefinition Height="34"/>
                            </Grid.RowDefinitions>

                            <CheckBox x:Name="showPrintbed"
                                      Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                                      Content="Show Printbed" IsChecked="{Binding ShowPrintbed}"
                                      VerticalAlignment="Center"
                                      Checked="CheckedChanged"
                                      Unchecked="CheckedChanged"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Background Top:" VerticalAlignment="Center"/>
                            <Border Grid.Row="1" Grid.Column="1"
                                    Style="{StaticResource SwatchStyle}"
                                    MouseLeftButtonUp="ColorSwatch_Click"
                                    Background="{Binding BackgroundTopColor, Converter={StaticResource UIntToBrushConverter}}"
                                    Tag="BackgroundTopColor"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Background Bottom:" VerticalAlignment="Center"/>
                            <Border Grid.Row="2" Grid.Column="1"
                                    Style="{StaticResource SwatchStyle}"
                                    MouseLeftButtonUp="ColorSwatch_Click"
                                    Background="{Binding BackgroundBottomColor, Converter={StaticResource UIntToBrushConverter}}"      
                                    Tag="BackgroundBottomColor"/>
                            
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Printer Base:" VerticalAlignment="Center"/>
                            <Border Grid.Row="3" Grid.Column="1"
                                    Style="{StaticResource SwatchStyle}"
                                    MouseLeftButtonUp="ColorSwatch_Click"
                                    Background="{Binding PrinterBaseColor, Converter={StaticResource UIntToBrushConverter}}"
                                    Tag="PrinterBaseColor"/>
                            
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Printer Frame:" VerticalAlignment="Center"/>
                            <Border Grid.Row="4" Grid.Column="1"
                                    Style="{StaticResource SwatchStyle}"
                                    MouseLeftButtonUp="ColorSwatch_Click"
                                    Background="{Binding PrinterFrameColor, Converter={StaticResource UIntToBrushConverter}}"             
                                    Tag="PrinterFrameColor"/>
              
                            <Label Grid.Row="0" Grid.Column="3" Grid.ColumnSpan="2" Content="Print Area Diemension" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            <Label Grid.Row="1" Grid.Column="3" Content="Width:" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            <Label Grid.Row="2" Grid.Column="3" Content="Depth:" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            <Label Grid.Row="3" Grid.Column="3" Content="Height:" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            <TextBox x:Name="txtPrintAreaWidth" Grid.Row="1" Grid.Column="4" Text="{Binding PrintAreaWidth}" Margin="0,6" LostFocus="uint_LostFocus"/>
                            <TextBox x:Name="txtPrintAreaDepth" Grid.Row="2" Grid.Column="4" Text="{Binding PrintAreaDepth}" Margin="0,6" LostFocus="uint_LostFocus"/>
                            <TextBox x:Name="txtPrintAreaHeight" Grid.Row="3" Grid.Column="4" Text="{Binding PrintAreaHeight}" Margin="0,6" LostFocus="uint_LostFocus"/>

                            <Label Grid.Row="0" Grid.Column="6" Grid.ColumnSpan="3" Content="Initial OpenGL Client Size" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            <Label Grid.Row="1" Grid.Column="6" Content="Width:" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            <Label Grid.Row="2" Grid.Column="6" Content="Height:" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            <TextBox x:Name="txtClientSizeWidth" Grid.Row="1" Grid.Column="7" Text="{Binding InitialClientSizeWidth}" Margin="0,6" LostFocus="uint_LostFocus"/>
                            <TextBox x:Name="txtClientSizeHeight" Grid.Row="2" Grid.Column="7" Text="{Binding InitialClientSizeHeight}" Margin="0,6" LostFocus="uint_LostFocus"/>

                            <Label Content="(Settings in right side needs restart to apply.)" Grid.Row="4" Grid.Column="3" Grid.ColumnSpan="5" HorizontalAlignment="Left" VerticalAlignment="Center" FontSize="10" Foreground="#888"/>
                        </Grid>
                    </GroupBox>
                    <Button Grid.Row="2" Content="Reset All Settings to Default" Width="200" Height="28" Margin="0,10" HorizontalAlignment="Left" VerticalAlignment="Bottom" Click="ResetSettings_Click"/>
                    <Button Grid.Row="2" Content="Open Settings File Folder" Width="150" Height="28" Margin="220,10,0,10" HorizontalAlignment="Left" VerticalAlignment="Bottom" Click="OpenSettingsFileFolder_Click"/>
                </Grid>
            </TabItem>

            <!-- ═══════════════════════════════════════════
                 TAB 2 — Model
            ════════════════════════════════════════════ -->
            <TabItem Header="Model">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <GroupBox Header="Colors" Grid.Row="0" Margin="0,0,0,8">
                        <Grid Margin="6,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="185"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="30"/>
                                <ColumnDefinition Width="145"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="34"/>
                                <RowDefinition Height="34"/>
                                <RowDefinition Height="34"/>
                                <RowDefinition Height="34"/>
                                <RowDefinition Height="34"/>
                                <RowDefinition Height="34"/>
                                <RowDefinition Height="34"/>
                            </Grid.RowDefinitions>

                            <!-- Left column -->
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Faces:" VerticalAlignment="Center"/>
                            <Border Grid.Row="0" Grid.Column="1" 
                                    Style="{StaticResource SwatchStyle}" 
                                    MouseLeftButtonUp="ColorSwatch_Click"
                                    Background="{Binding FacesColor, Converter={StaticResource UIntToBrushConverter}}"
                                    Tag="FacesColor"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Selected faces:" VerticalAlignment="Center"/>
                            <Border Grid.Row="1" Grid.Column="1" 
                                    Style="{StaticResource SwatchStyle}" 
                                    MouseLeftButtonUp="ColorSwatch_Click"
                                    Background="{Binding SelectedFacesColor, Converter={StaticResource UIntToBrushConverter}}"
                                    Tag="SelectedFacesColor"/>              

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Edges:" VerticalAlignment="Center"/>
                            <Border Grid.Row="2" Grid.Column="1" 
                                    Style="{StaticResource SwatchStyle}" 
                                    MouseLeftButtonUp="ColorSwatch_Click"
                                    Background="{Binding EdgesColor, Converter={StaticResource UIntToBrushConverter}}"
                                    Tag="EdgesColor"/>     

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Objects outside printbed:" VerticalAlignment="Center"/>
                            <Border Grid.Row="3" Grid.Column="1" 
                                    Style="{StaticResource SwatchStyle}" 
                                    MouseLeftButtonUp="ColorSwatch_Click"
                                    Background="{Binding OutsidePrintbedColor, Converter={StaticResource UIntToBrushConverter}}"
                                    Tag="OutsidePrintbedColor"/>   

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Selection Box:" VerticalAlignment="Center"/>
                            <Border Grid.Row="4" Grid.Column="1" 
                                    Style="{StaticResource SwatchStyle}" 
                                    MouseLeftButtonUp="ColorSwatch_Click"
                                    Background="{Binding SelectionBoxColor, Converter={StaticResource UIntToBrushConverter}}"
                                    Tag="SelectionBoxColor"/>    

                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Model errors (face):" VerticalAlignment="Center"/>
                            <Border Grid.Row="5" Grid.Column="1" 
                                    Style="{StaticResource SwatchStyle}" 
                                    MouseLeftButtonUp="ColorSwatch_Click"
                                    Background="{Binding ErrorModelColor, Converter={StaticResource UIntToBrushConverter}}"
                                    Tag="ErrorModelColor"/> 
                                        
                            <!-- Right column -->
                            <TextBlock Grid.Row="0" Grid.Column="3" Text="Inner faces:" VerticalAlignment="Center"/>
                            <Border Grid.Row="0" Grid.Column="4" 
                                    Style="{StaticResource SwatchStyle}" 
                                    MouseLeftButtonUp="ColorSwatch_Click"
                                    Background="{Binding InsideFacesColor, Converter={StaticResource UIntToBrushConverter}}"
                                    Tag="InsideFacesColor"/>

                            <!-- Model Color, EX: 0.6f, 0.7f, 0.8f / 154, 179, 205  -->
                            <TextBlock Grid.Row="4" Grid.Column="3" Text="Model Color:" VerticalAlignment="Center"/>
                            <Border Grid.Row="4" Grid.Column="4" 
                                    Style="{StaticResource SwatchStyle}" 
                                    MouseLeftButtonUp="ColorSwatch_Click"
                                    Background="{Binding ModelColor, Converter={StaticResource UIntToBrushConverter}}"
                                    Tag="ModelColor"/>          

                        </Grid>
                    </GroupBox>

                    <GroupBox Header="Editor" Grid.Row="1" Grid.ColumnSpan="2">
                        <StackPanel Margin="6,4" Orientation="Vertical">
                            <CheckBox x:Name="showEdges" Content="Show edges" IsChecked="{Binding ShowEdges}" Margin="0,4"
                                      Checked="CheckedChanged" Unchecked="CheckedChanged"/>
                            <CheckBox x:Name="showFaces" Content="Show faces" IsChecked="{Binding ShowFaces}" Margin="0,4"
                                      Checked="CheckedChanged" Unchecked="CheckedChanged"/>
                        </StackPanel>
                    </GroupBox>
                </Grid>
            </TabItem>

            <!-- ═══════════════════════════════════════════
                 TAB 3 — Lights
            ════════════════════════════════════════════ -->
            <TabItem Header="Lights" Height="20" VerticalAlignment="Top">
                <Grid Margin="12,12,12,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="36"/>
                        <RowDefinition Height="34"/>
                        <RowDefinition Height="34"/>
                        <RowDefinition Height="34"/>
                        <RowDefinition Height="34"/>
                        <RowDefinition Height="34"/>
                        <RowDefinition Height="34"/>
                        <RowDefinition Height="34"/>
                        <RowDefinition Height="34"/>
                        <RowDefinition Height="34"/>
                        <RowDefinition Height="34"/>
                        <RowDefinition Height="34"/>
                        <RowDefinition Height="34"/>
                    </Grid.RowDefinitions>

                    <!-- Light (Key) / Default Dir: -0.6, 1.0, 0.8, Default Color: 1.00, 0.98, 0.95 (#FFFAF2), Default Strength: 1.8 -->
                    <Label Grid.Row="0" Grid.Column="1" Content="Key" HorizontalAlignment="Center" VerticalAlignment="Center" VerticalContentAlignment="Center" FontSize="14"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="X Direction:" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding KeyDirX}" Margin="4,3" TextChanged="LightSetting_ValueChanged" LostFocus="float_LostFocus"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Y Direction:" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding KeyDirY}" Margin="4,3" TextChanged="LightSetting_ValueChanged" LostFocus="float_LostFocus"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Z Direction:" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding KeyDirZ}" Margin="4,3" TextChanged="LightSetting_ValueChanged" LostFocus="float_LostFocus"/>

                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Light Color:" VerticalAlignment="Center"/>
                    <Border Grid.Row="5" Grid.Column="1" 
                            Background="{Binding KeyColor, Converter={StaticResource UIntToBrushConverter}}"
                            Tag="KeyColor"
                            Style="{StaticResource SwatchStyle}" MouseLeftButtonUp="ColorSwatch_Click" Margin="4,3" 
                            ToolTip="{Binding RelativeSource={RelativeSource Self}, Path=Background, Converter={StaticResource BrushToFloatConverter}}"/>

                    <TextBlock Grid.Row="7" Grid.Column="0" Text="Strength:" VerticalAlignment="Center"/>
                    <Slider x:Name="sliderKeyStr" Grid.Row="7" Grid.Column="1" HorizontalAlignment="Left" VerticalAlignment="Center" Width="90" ValueChanged="LightSetting_ValueChanged" Minimum="0" Maximum="10" Value="{Binding KeyStr}"/>
                    <TextBlock Grid.Row="7" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" Text="{Binding ElementName=sliderKeyStr, Path=Value, StringFormat={}{0:0.0}}"/>

                    <!-- Light (fill) / Default Dir: 0.8, 0.3, 0.5, Default Color: 0.80, 0.88, 1.00 (#CCE0FF), Default Strength: 1.2-->
                    <Label Grid.Row="0" Grid.Column="2" Content="Fill" HorizontalAlignment="Center" VerticalAlignment="Center" VerticalContentAlignment="Center" FontSize="14"/>

                    <TextBox Grid.Row="1" Grid.Column="2" Text="{Binding FillDirX}" Margin="4,3" TextChanged="LightSetting_ValueChanged" LostFocus="float_LostFocus"/>
                    <TextBox Grid.Row="2" Grid.Column="2" Text="{Binding FillDirY}" Margin="4,3" TextChanged="LightSetting_ValueChanged" LostFocus="float_LostFocus"/>
                    <TextBox Grid.Row="3" Grid.Column="2" Text="{Binding FillDirZ}" Margin="4,3" TextChanged="LightSetting_ValueChanged" LostFocus="float_LostFocus"/>

                    <Border Grid.Row="5" Grid.Column="2"
                            Background="{Binding FillColor, Converter={StaticResource UIntToBrushConverter}}"
                            Tag="FillColor"
                            Style="{StaticResource SwatchStyle}" MouseLeftButtonUp="ColorSwatch_Click" Margin="4,3" 
                            ToolTip="{Binding RelativeSource={RelativeSource Self}, Path=Background, Converter={StaticResource BrushToFloatConverter}}"/>

                    <Slider x:Name="sliderFillStr" Grid.Row="7" Grid.Column="2" HorizontalAlignment="Left" VerticalAlignment="Center" Width="90" ValueChanged="LightSetting_ValueChanged" Minimum="0" Maximum="10" Value="{Binding FillStr}"/>
                    <TextBlock Grid.Row="7" Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center" Text="{Binding ElementName=sliderFillStr, Path=Value, StringFormat={}{0:0.0}}"/>

                    <!-- Light (back) / Default Dir: 0.1, -0.5, -1.0, Default Color: 0.90, 0.92, 1.00 (#E6EBFF), Default Strength: 0.9-->
                    <Label Grid.Row="0" Grid.Column="3" Content="Back" HorizontalAlignment="Center" VerticalAlignment="Center" VerticalContentAlignment="Center" FontSize="14"/>

                    <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding BackDirX}" Margin="4,3" TextChanged="LightSetting_ValueChanged" LostFocus="float_LostFocus"/>
                    <TextBox Grid.Row="2" Grid.Column="3" Text="{Binding BackDirY}" Margin="4,3" TextChanged="LightSetting_ValueChanged" LostFocus="float_LostFocus"/>
                    <TextBox Grid.Row="3" Grid.Column="3" Text="{Binding BackDirZ}" Margin="4,3" TextChanged="LightSetting_ValueChanged" LostFocus="float_LostFocus"/>

                    <Border Grid.Row="5" Grid.Column="3" 
                            Background="{Binding BackColor, Converter={StaticResource UIntToBrushConverter}}"
                            Tag="BackColor"
                            Style="{StaticResource SwatchStyle}" MouseLeftButtonUp="ColorSwatch_Click" Margin="4,3" 
                            ToolTip="{Binding RelativeSource={RelativeSource Self}, Path=Background, Converter={StaticResource BrushToFloatConverter}}"/>

                    <Slider x:Name="sliderBackStr" Grid.Row="7" Grid.Column="3" HorizontalAlignment="Left" VerticalAlignment="Center" Width="90" ValueChanged="LightSetting_ValueChanged" Minimum="0" Maximum="10" Value="{Binding BackStr}"/>
                    <TextBlock Grid.Row="7" Grid.Column="3" HorizontalAlignment="Right" VerticalAlignment="Center" Text="{Binding ElementName=sliderBackStr, Path=Value, StringFormat={}{0:0.0}}"/>

                    <!-- Ambient / Default Sky Color: 0.60, 0.70, 0.90 (#99B2E6), Default Ground Color: 0.25, 0.20, 0.18 (#40332E), Default Strength: 1.2 -->
                    <Label Grid.Row="0" Grid.Column="4" Content="Ambient" HorizontalAlignment="Center" VerticalAlignment="Center" VerticalContentAlignment="Center" FontSize="14"/>

                    <TextBlock Grid.Row="4" Grid.Column="3" Text="Sky Color:" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                    <Border Grid.Row="4" Grid.Column="4" 
                            Background="{Binding SkyColor, Converter={StaticResource UIntToBrushConverter}}"
                            Tag="SkyColor"
                            Style="{StaticResource SwatchStyle}" MouseLeftButtonUp="ColorSwatch_Click" Margin="4,3"
                            ToolTip="{Binding RelativeSource={RelativeSource Self}, Path=Background, Converter={StaticResource BrushToFloatConverter}}"/>
               
                    <TextBlock Grid.Row="6" Grid.Column="3" Text="Ground Color:" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                    <Border Grid.Row="6" Grid.Column="4" 
                            Background="{Binding GroundColor, Converter={StaticResource UIntToBrushConverter}}"
                            Tag="GroundColor"
                            Style="{StaticResource SwatchStyle}" MouseLeftButtonUp="ColorSwatch_Click" Margin="4,3" 
                            ToolTip="{Binding RelativeSource={RelativeSource Self}, Path=Background, Converter={StaticResource BrushToFloatConverter}}"/>

                    <Slider x:Name="sliderAmbientStr" Grid.Row="7" Grid.Column="4" HorizontalAlignment="Left" VerticalAlignment="Center" Width="90" ValueChanged="LightSetting_ValueChanged" Minimum="0" Maximum="10" Value="{Binding AmbientStr}"/>
                    <TextBlock Grid.Row="7" Grid.Column="4" HorizontalAlignment="Right" VerticalAlignment="Center" Text="{Binding ElementName=sliderAmbientStr, Path=Value, StringFormat={}{0:0.0}}"/>

                    <!-- Reset to default -->
                    <Button Grid.Row="10" Grid.Column="0" Margin="6" Content="Reset to default" Click="ResetLightSettingsToDefault_Click"/>

                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</Window>
